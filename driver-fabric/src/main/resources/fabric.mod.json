{
  "schemaVersion": 1,
  "id": "craftless-driver-fabric",
  "version": "${version}",
  "name": "Craftless Driver Fabric ${minecraftVersion} compiled lane",
  "description": "Craftless in-client driver compiled for Minecraft ${minecraftVersion}.",
  "authors": [
    "Minekube"
  ],
  "license": "Apache-2.0",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.minekube.craftless.driver.fabric.CraftlessFabricClientEntrypoint"
    ]
  },
  "mixins": [
    "craftless-driver-fabric.mixins.json"
  ],
  "depends": {
    "fabric-api": ">=${fabricApiVersion}",
    "fabricloader": ">=${fabricLoaderVersion}",
    "minecraft": "${minecraftVersion}",
    "java": ">=${javaMajorVersion}"
  }
}

{
  "name": "craftless-docs-site",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "deploy": "wrangler deploy",
    "dev": "next dev",
    "openapi:generate": "mise run docs-site-openapi",
    "preview:upload": "wrangler versions upload --preview-alias preview",
    "typecheck": "fumadocs-mdx && tsc --noEmit"
  },
  "dependencies": {
    "fumadocs-core": "16.10.7",
    "fumadocs-mdx": "15.0.13",
    "fumadocs-openapi": "11.0.6",
    "fumadocs-ui": "16.10.7",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shiki": "4.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/mdx": "2.0.14",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "wrangler": "^4.105.0"
  }
}

{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "craftless-docs",
  "compatibility_date": "2026-06-29",
  "compatibility_flags": ["nodejs_compat"],
  "preview_urls": true,
  "assets": {
    "directory": "./out",
    "html_handling": "force-trailing-slash",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
